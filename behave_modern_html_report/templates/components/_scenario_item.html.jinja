<li class="scenario" data-status="{{ scenario.status }}"
    data-name="{{ scenario.name|lower }}"
    data-tags="{{ scenario.tags|join(',')|lower }}"
    data-feature="{{ scenario.feature_name|lower }}"
    data-rule="{{ scenario.rule_name|lower }}"
    data-duration="{{ scenario.duration }}"
    data-error="{{ (scenario.error.message|lower) if scenario.error else '' }}">
{% set repro_cmd = "behave " ~ scenario.location if scenario.location else "behave -t @" ~ scenario.tags|join(' -t @') if scenario.tags else 'behave' %}
  <div class="scenario-row-header">
    <button class="scenario-head" aria-expanded="false">
      <svg class="ico chev"><use href="#i-chevron"/></svg>
      <span class="status-badge status-{{ scenario.status }}">
        <svg class="ico"><use href="#i-{{ scenario.status|status_icon }}"/></svg>
        {{ scenario.status|status_label }}
      </span>
      <div class="scenario-meta">
        <span class="scenario-title">{{ scenario.name or "(unnamed scenario)" }}</span>
        <span class="muted">{{ scenario.duration|duration }}</span>
      </div>
      <div class="tags">
        {% for tag in scenario.tags %}<span class="tag">@{{ tag }}</span>{% endfor %}
      </div>
    </button>
    <button class="icon-btn copy-btn" title="Copy reproduce command" aria-label="Copy reproduce command"
            data-copy-text="{{ repro_cmd }}" type="button">
      <svg class="ico"><use href="#i-terminal"/></svg>
    </button>
  </div>
  <div class="scenario-body" hidden>
    {% if scenario.description %}<p class="desc">{{ scenario.description }}</p>{% endif %}
    {% if scenario.location %}<p class="muted small">{{ scenario.location }}</p>{% endif %}

    {% if scenario.background and scenario.background.steps %}
      <div class="background-block detailed-only">
        <div class="background-head">
          <svg class="ico"><use href="#i-bg"/></svg>
          <span class="background-label">{{ scenario.background.keyword }}</span>
          <span class="muted small">{{ scenario.background.name }}</span>
        </div>
        <ol class="steps background-steps">
          {% set max_step_duration = scenario.background.steps|map(attribute='duration')|max|default(0.0) %}
          {% for step in scenario.background.steps %}
            {% include "components/step.html.jinja" %}
          {% endfor %}
        </ol>
      </div>
    {% endif %}

    {% if scenario.is_outline %}
      <div class="outline-banner detailed-only">
        <span class="outline-label">Scenario Outline</span>
        {% if scenario.outline_name %}<span class="outline-name">{{ scenario.outline_name }}</span>{% endif %}
      </div>
    {% endif %}

    {% set max_step_duration = scenario.steps|map(attribute='duration')|max|default(0.0) %}
    <ol class="steps">
      {% for step in scenario.steps %}
        {% include "components/step.html.jinja" %}
      {% endfor %}
    </ol>

    {% if scenario.examples and scenario.examples.headings %}
      <div class="examples-block detailed-only">
        <div class="examples-head">Examples</div>
        <div class="table-wrap">
          <table class="data-table examples-table">
            <thead><tr>{% for h in scenario.examples.headings %}<th>{{ h }}</th>{% endfor %}</tr></thead>
            <tbody>
              {% for row in scenario.examples.rows %}
                <tr>{% for cell in row %}<td>{{ cell }}</td>{% endfor %}</tr>
              {% endfor %}
            </tbody>
          </table>
        </div>
      </div>
    {% endif %}
  </div>
</li>
