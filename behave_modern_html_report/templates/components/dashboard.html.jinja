{% set stats = execution.statistics %}
<section class="view" data-view="dashboard">
  <header class="view-header">
    <div>
      <h1 class="view-title">{{ options.title }}</h1>
      <p class="view-sub">
        {% if stats.start_time %}Started {{ stats.start_time.strftime('%Y-%m-%d %H:%M:%S') }} · {% endif %}
        Duration {{ stats.duration|duration }} · {{ stats.total_features }} features · {{ stats.total_scenarios }} scenarios
      </p>
    </div>
    <div class="status-pill status-{{ execution.overall_status }}">
      <svg class="ico"><use href="#i-{{ execution.overall_status|status_icon }}"/></svg>
      <span>{{ execution.overall_status|status_label }}</span>
    </div>
  </header>

  <div class="cards">
    <div class="card stat-card stat-passed">
      <div class="stat-label">Passed</div>
      <div class="stat-value">{{ stats.passed }}</div>
      <div class="stat-foot">{{ '%.1f'|format(stats.pass_rate) }}% pass rate</div>
    </div>
    <div class="card stat-card stat-failed">
      <div class="stat-label">Failed</div>
      <div class="stat-value">{{ stats.failed }}</div>
      <div class="stat-foot">{{ stats.error_count }} with error</div>
    </div>
    <div class="card stat-card stat-skipped">
      <div class="stat-label">Skipped</div>
      <div class="stat-value">{{ stats.skipped }}</div>
      <div class="stat-foot">scenarios</div>
    </div>
    <div class="card stat-card stat-undefined">
      <div class="stat-label">Undefined</div>
      <div class="stat-value">{{ stats.undefined }}</div>
      <div class="stat-foot">scenarios</div>
    </div>
    <div class="card stat-card stat-pending">
      <div class="stat-label">Pending</div>
      <div class="stat-value">{{ stats.pending }}</div>
      <div class="stat-foot">scenarios</div>
    </div>
    <div class="card stat-card stat-total">
      <div class="stat-label">Total</div>
      <div class="stat-value">{{ stats.total_scenarios }}</div>
      <div class="stat-foot">{{ stats.total_features }} features · {{ stats.total_steps }} steps</div>
    </div>
    <div class="card stat-card stat-total">
      <div class="stat-label">Rules</div>
      <div class="stat-value">{{ stats.rule_count }}</div>
      <div class="stat-foot">{{ stats.rule_failed_count }} failed</div>
    </div>
    <div class="card stat-card stat-total">
      <div class="stat-label">Avg duration</div>
      <div class="stat-value">{{ stats.avg_scenario_duration|duration }}</div>
      <div class="stat-foot">slowest step {{ stats.slowest_step_duration|duration }}</div>
    </div>
    <div class="card stat-card stat-total">
      <div class="stat-label">Attachments</div>
      <div class="stat-value">{{ stats.total_attachments }}</div>
      <div class="stat-foot">{{ stats.total_logs }} logs</div>
    </div>
    <div class="card stat-card stat-total">
      <div class="stat-label">Errors</div>
      <div class="stat-value">{{ stats.error_count }}</div>
      <div class="stat-foot">{{ stats.common_exception_type or 'none' }}</div>
    </div>
  </div>

  <div class="card progress-card">
    <div class="progress-bar stacked" aria-label="Execution status progress">
      {% set total = stats.total_scenarios or 1 %}
      {% for s in ["passed","failed","skipped","undefined","pending"] %}
        {% set count = stats.by_status.get(s, 0) %}
        {% if count > 0 %}
          <div class="progress-segment status-{{ s }}" style="width: {{ (count / total * 100)|round(1) }}%;" title="{{ s|status_label }}: {{ count }}"></div>
        {% endif %}
      {% endfor %}
    </div>
    <div class="progress-legend">
      {% for s in ["passed","failed","skipped","undefined","pending"] %}
        {% set count = stats.by_status.get(s, 0) %}
        {% if count > 0 %}
          <span class="progress-legend-item">
            <span class="status-dot status-{{ s }}"></span>
            {{ s|status_label }} {{ count }}
          </span>
        {% endif %}
      {% endfor %}
      <span class="progress-pass-rate">{{ '%.1f'|format(stats.pass_rate) }}% pass rate</span>
    </div>
  </div>

  <div class="dashboard-actions">
    <button class="copy-btn" id="copy-summary" data-copy-target="#summary-text" type="button">
      <svg class="ico"><use href="#i-copy"/></svg>
      Copy summary
    </button>
    <textarea id="summary-text" class="summary-text" readonly aria-hidden="true">{% if execution.overall_status == 'passed' %}✅{% elif execution.overall_status == 'failed' %}❌{% else %}⚠️{% endif %} *{{ options.title }}*
{% if execution.overall_status == 'passed' %}*All passed*{% elif execution.overall_status == 'failed' %}*{{ stats.error_count }} scenario(s) failed*{% else %}*{{ execution.overall_status|status_label }}*{% endif %}

📊 {{ stats.total_scenarios }} scenarios · {{ stats.total_features }} features · {{ stats.total_steps }} steps
⏱️ Duration {{ stats.duration|duration }} · Avg {{ stats.avg_scenario_duration|duration }}
📈 Pass rate {{ '%.1f'|format(stats.pass_rate) }}%

{% if stats.failed %}🔴 Failed: {{ stats.failed }}
{% endif %}{% if stats.passed %}🟢 Passed: {{ stats.passed }}
{% endif %}{% if stats.skipped %}⚪ Skipped: {{ stats.skipped }}
{% endif %}{% if stats.undefined %}🟡 Undefined: {{ stats.undefined }}
{% endif %}{% if stats.pending %}🟣 Pending: {{ stats.pending }}
{% endif %}{% if stats.common_exception_type %}
💥 Most common error: {{ stats.common_exception_type }}
{% endif %}{% if stats.rule_count %}
📜 Rules: {{ stats.rule_count }} ({{ stats.rule_failed_count }} failed)
{% endif %}</textarea>
  </div>

  <div class="grid-3">
    <div class="card chart-card">
      <h3 class="card-title">Status distribution</h3>
      <canvas id="chart-status" height="200" aria-label="Status pie chart"></canvas>
    </div>
    <div class="card chart-card">
      <h3 class="card-title">Scenarios over time</h3>
      <canvas id="chart-timeline" height="200" aria-label="Timeline chart"></canvas>
    </div>
    <div class="card chart-card">
      <h3 class="card-title">Duration histogram</h3>
      <canvas id="chart-buckets" height="200" aria-label="Duration histogram chart"></canvas>
    </div>
    <div class="card chart-card">
      <h3 class="card-title">Slowest scenarios</h3>
      <canvas id="chart-slowest" height="200" aria-label="Slowest scenarios chart"></canvas>
    </div>
    <div class="card chart-card">
      <h3 class="card-title">Tags with worst pass rate</h3>
      <canvas id="chart-tag-pass" height="200" aria-label="Tag pass rate chart"></canvas>
    </div>
    <div class="card chart-card">
      <h3 class="card-title">Error distribution</h3>
      <canvas id="chart-errors" height="200" aria-label="Error distribution chart"></canvas>
    </div>
  </div>
</section>
