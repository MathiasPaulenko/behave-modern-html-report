<section class="view" data-view="features" hidden>
  <header class="view-header">
    <div>
      <h1 class="view-title">Features</h1>
      <p class="view-sub">{{ execution.features|length }} features · {{ execution.statistics.total_scenarios }} scenarios</p>
    </div>
    <div class="view-actions">
      <button class="action-btn" data-expand-all=".feature" type="button">Expand all</button>
      <button class="action-btn" data-collapse-all=".feature" type="button">Collapse all</button>
      <div class="mode-group" role="group" aria-label="Feature view mode">
        <button class="action-btn" data-view-mode="compact" data-target="features-list" type="button">Compact mode</button>
        <button class="action-btn" data-view-mode="detailed" data-target="features-list" type="button">Detailed mode</button>
      </div>
    </div>
  </header>

  <div id="features-list" class="stack">
    {# Features are server-rendered for SEO/printability; JS handles filtering and search. #}
    {% for feature in execution.features %}
      <article class="feature card" data-status="{{ feature.status }}"
               data-name="{{ feature.name|lower }}"
               data-tags="{{ feature.tags|join(',')|lower }}">
        <button class="feature-head" aria-expanded="false">
          <svg class="ico chev"><use href="#i-chevron"/></svg>
          <span class="status-dot status-{{ feature.status }}"></span>
          <div class="feature-meta">
            <h2 class="feature-title">{{ feature.name or "(unnamed feature)" }}</h2>
            <div class="feature-sub">
              <span>{{ feature.scenario_count }} scenarios</span>
              <span>·</span>
              <span>{{ feature.duration|duration }}</span>
              {% if feature.location %}<span>·</span><span class="muted">{{ feature.location }}</span>{% endif %}
            </div>
          </div>
          <div class="tags">
            {% for tag in feature.tags %}<span class="tag">@{{ tag }}</span>{% endfor %}
          </div>
        </button>
        <div class="feature-body" hidden>
          {% if feature.description %}<p class="desc">{{ feature.description }}</p>{% endif %}
          {% for rule_name, rule_scenarios in feature.scenarios|groupby('rule_name') %}
            {% if rule_name %}
              <div class="rule" data-rule="{{ rule_name|lower }}">
                <button class="rule-head" aria-expanded="false">
                  <svg class="ico chev"><use href="#i-chevron"/></svg>
                  <span class="rule-label">Rule</span>
                  <span class="rule-title">{{ rule_name }}</span>
                  <span class="rule-count">{{ rule_scenarios|length }} scenario{{ 's' if rule_scenarios|length > 1 else '' }}</span>
                </button>
                <div class="rule-body" hidden>
                  <ol class="scenarios">
                    {% for scenario in rule_scenarios %}
                      {% include "components/_scenario_item.html.jinja" %}
                    {% endfor %}
                  </ol>
                </div>
              </div>
            {% else %}
              <ol class="scenarios">
                {% for scenario in rule_scenarios %}
                  {% include "components/_scenario_item.html.jinja" %}
                {% endfor %}
              </ol>
            {% endif %}
          {% endfor %}
        </div>
      </article>
    {% endfor %}
  </div>
</section>
