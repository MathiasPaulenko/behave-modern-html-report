<section class="view" data-view="rules" hidden>
  <header class="view-header">
    <div>
      <h1 class="view-title">Rules</h1>
      <p class="view-sub">All Gherkin Rules grouped by feature.</p>
    </div>
    <div class="view-actions">
      <button class="action-btn" data-expand-all=".rule.card" type="button">Expand all</button>
      <button class="action-btn" data-collapse-all=".rule.card" type="button">Collapse all</button>
      <div class="mode-group" role="group" aria-label="Rules view mode">
        <button class="action-btn" data-view-mode="compact" data-target="rules-list" type="button">Compact mode</button>
        <button class="action-btn" data-view-mode="detailed" data-target="rules-list" type="button">Detailed mode</button>
      </div>
    </div>
  </header>

  <div id="rules-list" class="stack">
    {% for feature in execution.features %}
      {% for rule_name, rule_scenarios in feature.scenarios|groupby('rule_name') %}
        {% if rule_name %}
          <article class="rule card" data-rule="{{ rule_name|lower }}"
                   data-feature="{{ feature.name|lower }}"
                   data-tags="{{ rule_scenarios|map(attribute='tags')|sum(start=[])|unique|join(',')|lower }}">
            <button class="rule-head" aria-expanded="false">
              <svg class="ico chev"><use href="#i-chevron"/></svg>
              <span class="rule-label">Rule</span>
              <div class="rule-meta">
                <span class="rule-title">{{ rule_name }}</span>
                <span class="rule-sub">{{ feature.name }} · {{ rule_scenarios|length }} scenario{{ 's' if rule_scenarios|length > 1 else '' }}</span>
              </div>
              <div class="tags">
                {% for tag in rule_scenarios|map(attribute='tags')|sum(start=[])|unique %}
                  <span class="tag">@{{ tag }}</span>
                {% endfor %}
              </div>
            </button>
            <div class="rule-body" hidden>
              <ol class="scenarios">
                {% for scenario in rule_scenarios %}
                  {% include "components/_scenario_item.html.jinja" %}
                {% endfor %}
              </ol>
            </div>
          </article>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
</section>
