<section class="view" data-view="scenarios" hidden>
  <header class="view-header">
    <div>
      <h1 class="view-title">Scenarios</h1>
      <p class="view-sub">All scenarios across all features.</p>
    </div>
    <div class="view-actions">
      <button class="action-btn" data-expand-all=".scenario" type="button">Expand all</button>
      <button class="action-btn" data-collapse-all=".scenario" type="button">Collapse all</button>
      <div class="mode-group" role="group" aria-label="Scenario view mode">
        <button class="action-btn" data-view-mode="compact" type="button">Compact mode</button>
        <button class="action-btn" data-view-mode="detailed" type="button">Detailed mode</button>
      </div>
    </div>
  </header>
  <ol class="scenarios stack" id="scenarios-list">
    {% for feature in execution.features %}
      {% for scenario in feature.scenarios %}
        {% include "components/_scenario_item.html.jinja" %}
      {% endfor %}
    {% endfor %}
  </ol>
</section>
