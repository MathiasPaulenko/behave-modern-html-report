<!doctype html>
<html lang="en" data-theme="{{ options.theme }}">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{{ options.title }}</title>
  <meta name="generator" content="behave-modern-html-report" />
  <style>{{ css|safe }}</style>
</head>
<body>
  {% include "components/icons.html.jinja" %}

  <a class="skip-link" href="#main">Skip to content</a>

  <aside class="sidebar" aria-label="Primary">
    <div class="brand">
      {% if options.logo_url %}
        <img class="brand-logo" src="{{ options.logo_url }}" alt="" />
      {% else %}
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="22" height="22"><path fill="currentColor" d="M12 2 3 7v10l9 5 9-5V7l-9-5Zm0 2.2 6.5 3.6L12 11.4 5.5 7.8 12 4.2ZM5 9.6l6 3.4v7.2L5 16.8V9.6Zm14 0v7.2l-6 3.4V13l6-3.4Z"/></svg>
        </span>
      {% endif %}
      <div class="brand-text">
        <div class="brand-title">{{ options.title }}</div>
        {% if options.company %}<div class="brand-sub">{{ options.company }}</div>{% endif %}
      </div>
    </div>

    <nav class="nav" aria-label="Sections">
      <button class="nav-item is-active" data-route="dashboard">
        <svg class="ico"><use href="#i-grid"/></svg><span>Dashboard</span>
      </button>
      <button class="nav-item" data-route="features">
        <svg class="ico"><use href="#i-folder"/></svg><span>Features</span>
      </button>
      <button class="nav-item" data-route="rules">
        <svg class="ico"><use href="#i-rules"/></svg><span>Rules</span>
      </button>
      <button class="nav-item" data-route="scenarios">
        <svg class="ico"><use href="#i-list"/></svg><span>Scenarios</span>
      </button>
      <button class="nav-item" data-route="tags">
        <svg class="ico"><use href="#i-tag"/></svg><span>Tags</span>
      </button>
      <button class="nav-item" data-route="statistics">
        <svg class="ico"><use href="#i-chart"/></svg><span>Statistics</span>
      </button>
      <button class="nav-item" data-route="environment">
        <svg class="ico"><use href="#i-cpu"/></svg><span>Environment</span>
      </button>
    </nav>

    <div class="sidebar-footer">
      <div class="footer-row">
        <span class="version">Behave Modern Report</span>
        <button id="theme-toggle" class="icon-btn" aria-label="Toggle theme" title="Toggle theme">
          <svg class="ico"><use href="#i-sun"/></svg>
        </button>
      </div>
    </div>
  </aside>

  <main id="main" class="main">
    <header class="topbar">
      <div class="search-wrap">
        <svg class="ico search-ico"><use href="#i-search"/></svg>
        <input id="global-search" type="search" placeholder="Search features, scenarios, steps, tags…" aria-label="Search" />
        <kbd class="kbd">/</kbd>
      </div>
      <div class="filters">
        {% for s in ["passed","failed","skipped","undefined","pending"] %}
          <button class="chip chip-{{ s }}" data-filter-status="{{ s }}" aria-pressed="true">
            <svg class="ico"><use href="#i-{{ s|status_icon }}"/></svg>
            <span>{{ s|status_label }}</span>
            <em data-count="{{ s }}">0</em>
          </button>
        {% endfor %}
      </div>
      <button id="filters-toggle" class="icon-btn" aria-label="Toggle advanced filters" title="Advanced filters" type="button">
        <svg class="ico"><use href="#i-filter"/></svg>
      </button>
    </header>
    <div id="advanced-filters" class="advanced-filters" hidden>
      <div class="filter-row">
        <label class="filter-field">
          <span>Tags</span>
          <input id="filter-tags" type="text" placeholder="payment, smoke…" aria-label="Filter by tags" />
        </label>
        <label class="filter-field">
          <span>Min duration (s)</span>
          <input id="filter-min-duration" type="number" min="0" step="0.1" placeholder="0" aria-label="Minimum duration in seconds" />
        </label>
        <label class="filter-field filter-checkbox">
          <input id="filter-error-text" type="checkbox" aria-label="Search in error text" />
          <span>Search in error text</span>
        </label>
      </div>
    </div>

    {% include "components/dashboard.html.jinja" %}
    {% include "components/feature.html.jinja" %}
    {% include "components/rules.html.jinja" %}
    {% include "components/scenario.html.jinja" %}
    {% include "components/tags.html.jinja" %}
    {% include "components/statistics.html.jinja" %}
    {% include "components/environment.html.jinja" %}

    <footer class="footer">
      Generated by <strong>behave-modern-html-report</strong> · {{ now.strftime('%Y-%m-%d %H:%M:%S') }}
    </footer>
  </main>

  <div id="lightbox" class="lightbox" hidden role="dialog" aria-modal="true" aria-label="Attachment preview">
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <div class="lightbox-content"></div>
  </div>

  <script id="bmr-data" type="application/json">{{ data_json|safe }}</script>
  <script>{{ js|safe }}</script>
</body>
</html>
