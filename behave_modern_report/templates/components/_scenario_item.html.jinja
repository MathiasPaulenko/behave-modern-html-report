<li class="scenario" data-status="{{ scenario.status }}"
    data-name="{{ scenario.name|lower }}"
    data-tags="{{ scenario.tags|join(',')|lower }}"
    data-feature="{{ scenario.feature_name|lower }}">
  <button class="scenario-head" aria-expanded="false">
    <svg class="ico chev"><use href="#i-chevron"/></svg>
    <span class="status-badge status-{{ scenario.status }}">
      <svg class="ico"><use href="#i-{{ scenario.status|status_icon }}"/></svg>
      {{ scenario.status|status_label }}
    </span>
    <div class="scenario-meta">
      <span class="scenario-title">{{ scenario.name or "(unnamed scenario)" }}</span>
      <span class="muted">{{ scenario.duration|duration }}</span>
    </div>
    <div class="tags">
      {% for tag in scenario.tags %}<span class="tag">@{{ tag }}</span>{% endfor %}
    </div>
  </button>
  <div class="scenario-body" hidden>
    {% if scenario.description %}<p class="desc">{{ scenario.description }}</p>{% endif %}
    {% if scenario.location %}<p class="muted small">{{ scenario.location }}</p>{% endif %}
    <ol class="steps">
      {% for step in scenario.steps %}
        {% include "components/step.html.jinja" %}
      {% endfor %}
    </ol>
  </div>
</li>
