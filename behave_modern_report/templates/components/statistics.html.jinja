<section class="view" data-view="statistics" hidden>
  <header class="view-header">
    <h1 class="view-title">Statistics</h1>
    <p class="view-sub">Distribution and performance analytics.</p>
  </header>

  <div class="grid-2">
    <div class="card chart-card">
      <h3 class="card-title">Status</h3>
      <canvas id="chart-status-2" height="240"></canvas>
    </div>
    <div class="card chart-card">
      <h3 class="card-title">Duration buckets</h3>
      <canvas id="chart-buckets" height="240"></canvas>
    </div>
  </div>

  <div class="card chart-card">
    <h3 class="card-title">Slowest scenarios</h3>
    <canvas id="chart-slowest" height="320"></canvas>
  </div>
</section>
